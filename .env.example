# Aegis-RiskGuard environment variables
# Copy this file to .env (local dev) or set via your cloud provider dashboard.

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AEGIS_PROVIDER to 'claude' for Claude Opus 4.7 (premium reasoning).
# Defaults to 'gemini' if unset or if ANTHROPIC_API_KEY is absent.
AEGIS_PROVIDER=gemini

# ── Gemini (free tier: gemini-2.5-flash; billing required for gemini-2.5-pro) ─
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_REASONING=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash

# ── Claude / Anthropic (optional — premium reasoning provider) ────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL_REASONING=claude-opus-4-7
CLAUDE_MODEL_FAST=claude-sonnet-4-6

# ── Security ──────────────────────────────────────────────────────────────────
# HMAC key for signing audit log entries. Generate: openssl rand -hex 32
LOBSTERTRAP_AUDIT_HMAC_KEY=change-me-to-a-random-32-byte-hex

# ── Demo / operational ────────────────────────────────────────────────────────
# Set to 'true' to skip all AI calls and return pre-computed gaps (offline demo backup)
DEMO_OFFLINE_MODE=false
