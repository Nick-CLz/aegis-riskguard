# Aegis-RiskGuard environment variables
# Copy to .env.local for local dev; set on Vultr VM for production

# REQUIRED — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional — used to sign the audit log entries (HMAC). Generate with: openssl rand -hex 32
LOBSTERTRAP_AUDIT_HMAC_KEY=change-me-to-a-random-32-byte-hex

# Model selection — keep these defaults unless you know why you're changing them
GEMINI_MODEL_REASONING=gemini-2.5-pro
GEMINI_MODEL_FAST=gemini-2.5-flash

# Demo mode — if 'true', uses canned outputs instead of calling Gemini (useful for offline demo backup)
DEMO_OFFLINE_MODE=false
